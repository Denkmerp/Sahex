                Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)

            elseif
                string.find(game.Players:FindFirstChild(LP.Name).PlayerGui.GUI.Frames.Notifications.ActiveNotification.Text:lower(), "secret") then
                    Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                    Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                    Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                    Character:MoveTo(PlrPlot.Floor1.BuyFloor.Part.Position)
                    
                    game.Players:FindFirstChild(LP.Name).PlayerGui.GUI.Frames.Notifications.ActiveNotification:Destroy()

            else
                print("Fack nah")
                wait(1)
            end
        end

        wait()
    end
end

